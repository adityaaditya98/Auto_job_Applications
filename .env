PORT=3000
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=MyStrongPassword123
NODE_ENV=development

OLLAMA_HOST=http://host.docker.internal:11434
LLM_PROVIDER=ollama
LLM_MODULE_TYPE=qwen3:8b
LM_STUDIO_HOST=http://host.docker.internal:1234

BULLMQ_ATTEMPTS=3
